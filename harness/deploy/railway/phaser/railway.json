{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.phaser",
    "watchPatterns": [
      "Dockerfile.phaser",
      "railway.json",
      "harness/deploy/railway/phaser/**",
      "harness/runtime/**",
      "harness/tools/**",
      "harness/content/ninja2/**",
      "harness/game-profiles/ninja2.profile.yaml",
      "harness/engine-contract/**",
      "engine/commons/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
