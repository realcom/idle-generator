{
  "name": "trigger-editor-electron",
  "productName": "Trigger Editor",
  "version": "1.0.0",
  "description": "Trigger editor using Electron",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make-darwin": "electron-forge make --arch=\"x64,arm64\" --platform=darwin",
    "make-windows": "electron-forge make --arch=\"ia32,x64,arm64\" --platform=win32",
    "make-linux": "electron-forge make --arch=\"ia32,x64,arm64\" --platform=linux",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron-forge/plugin-webpack": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "css-loader": "^6.11.0",
    "electron": "30.0.8",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "node-loader": "^2.0.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "keywords": [],
  "author": {
    "name": "Daemon",
    "email": "pm-Daemon@users.noreply.github.com"
  },
  "license": "proprietary",
  "dependencies": {
    "@types/awesomplete": "^1.1.16",
    "awesomplete": "^1.1.7",
    "blockly": "^11.1.1",
    "electron-settings": "^4.0.4",
    "electron-squirrel-startup": "^1.0.1",
    "highlight.js": "^11.10.0",
    "protobufjs": "^7.4.0",
    "smalltalk": "^4.1.2",
    "tree-kill": "^1.2.2"
  }
}
